{
  "openapi": "3.0.3",
  "info": {
    "title": "CinePro API",
    "description": "CinePro API provides endpoints to fetch movie and TV show streaming sources from various providers.\n\nThis project is for educational purposes only. We do not host any kind of content. We provide only the links to already available content on the internet. We do not host, upload any videos, films or media files. We are not responsible for the accuracy, compliance, copyright, legality, decency, or any other aspect of the content of other linked sites. If you have any legal issues please contact the appropriate media file owners or host sites.\n\nYou can use this project for personal and NON-COMMERCIAL use ONLY! You are NOT allowed to SELL this project or any part of it and/or ADD ANY KIND of tracking or advertisement to it.\n",
    "version": "0.0.1",
    "license": {
      "name": "Custom License",
      "url": "https://github.com/cinepro-org/backend"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "x-hidden": true,
        "summary": "API Home",
        "description": "Returns basic information about the API",
        "operationId": "getHome",
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "home": {
                      "type": "string",
                      "example": "CinePro API"
                    },
                    "routes": {
                      "type": "object",
                      "properties": {
                        "MOVIE": {
                          "type": "string",
                          "example": "/movie/:tmdbID"
                        },
                        "TV": {
                          "type": "string",
                          "example": "/tv/:tmdbID?s=seasonNumber&e=episodeNumber"
                        }
                      }
                    },
                    "information": {
                      "type": "string"
                    },
                    "license": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string",
                      "format": "url",
                      "example": "https://GitHub.com/cinepro-org/backend"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/movie/{tmdbId}": {
      "get": {
        "summary": "Get Movie Sources",
        "description": "Returns streaming sources for a movie by TMDB ID",
        "operationId": "getMovieSources",
        "parameters": [
          {
            "name": "tmdbId",
            "in": "path",
            "description": "TMDB ID of the movie",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaResponse"
                }
              }
            }
          },
          "405": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/movie/": {
      "get": {
        "x-hidden": true,
        "summary": "Invalid Movie Request",
        "description": "Returns an error for invalid movie requests",
        "operationId": "getInvalidMovie",
        "responses": {
          "405": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tv/{tmdbId}": {
      "get": {
        "summary": "Get TV Show Sources",
        "description": "Returns streaming sources for a TV show by TMDB ID, season, and episode",
        "operationId": "getTvSources",
        "parameters": [
          {
            "name": "tmdbId",
            "in": "path",
            "description": "TMDB ID of the TV show",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          },
          {
            "name": "s",
            "in": "query",
            "description": "Season number",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          },
          {
            "name": "e",
            "in": "query",
            "description": "Episode number",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaResponse"
                }
              }
            }
          },
          "405": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tv/": {
      "get": {
        "x-hidden": true,
        "summary": "Invalid TV Request",
        "description": "Returns an error for invalid TV requests",
        "operationId": "getInvalidTv",
        "responses": {
          "405": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{path}": {
      "get": {
        "x-hidden": true,
        "summary": "Route Not Found",
        "description": "Returns a 404 error for any undefined routes",
        "operationId": "getRouteNotFound",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "description": "Any undefined path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "404": {
            "description": "Route not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MediaResponse": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "description": "Array of video files (see what kind of files below) from various sources",
            "items": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string",
                  "description": "URL to the video file",
                  "format": "uri"
                },
                "type": {
                  "type": "string",
                  "description": "Type of the video file",
                  "enum": [
                    "hls",
                    "mp4",
                    "unknown"
                  ]
                },
                "lang": {
                  "type": "string",
                  "description": "Language of the video file (might not always be accurate | Follow ISO 639-1 standard)"
                }
              }
            }
          },
          "subtitles": {
            "type": "array",
            "description": "Array of subtitle files",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "description": "URL to the subtitle file",
                  "format": "uri"
                },
                "lang": {
                  "type": "string",
                  "description": "Language of the subtitle file (might not always be accurate | Follow ISO 639-1 standard)"
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "description": "Array of errors (Attention: You will only see this in debug mode)",
            "items": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message describing what went wrong"
          },
          "response": {
            "type": "integer",
            "description": "HTTP response code (if debug mode is on and you are scraping, this number will be the response code of provider. Not the actual API response code)"
          },
          "hint": {
            "type": "string",
            "description": "Hint to help resolve the error (if debug mode is on, you will see a possible reason for the error; not a solution)"
          },
          "error": {
            "type": "boolean",
            "description": "Always true"
          },
          "reportTo": {
            "type": "string",
            "description": "If you get this field, it means that the error is not yet known in your version. Please check /general-information/development#bug-reporting for more information and what to do next."
          }
        }
      }
    }
  }
}