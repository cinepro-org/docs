{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CinePro Docs",
  "description": "CinePro is a powerful is an open-source movie and TV show scraper API designed to provide links to media content available on the internet. It is built with a focus on performance, reliability, and ease of use, making it an ideal choice for developers looking to integrate media content such as movies and tv shows into their applications.",
  "colors": {
    "primary": "#f5413f",
    "light": "#f5413f",
    "dark": "#f5413f"
  },
  "favicon": "/logo/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          }, 
          {
            "group": "General Information",
            "pages": [
              "general-information/license",
              "general-information/development",
              "general-information/faq"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "General Information",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Scraping Endpoints",
            "pages": [
              "api-reference/get-movie-sources",
              "api-reference/get-tv-show-sources"
            ]
          }
        ]
      },
      {
        "tab": "Versions",
        "groups": [
          {
            "group": "Versions",
            "pages": [
              "versions"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/cinepro-org/backend",
          "icon": "github"
        },
        { 
          "anchor": "Community",
          "href": "https://github.com/orgs/cinepro-org/discussions/",
          "icon": "people-group"
        }
      ]
    }
  },
  "navbar": {
    "primary": 
      {
        "type": "button",
        "label": "Get Started",
        "href": "https://cinepro.mintlify.app/quickstart"
      }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cinepro-org"
    }
  },
  "background": {
    "decoration": "windows",
    "color": {
      "dark": "#0f0000"
    }
  },
  "integrations": {
    "telemetry": {
      "enabled": false
    }
  },
  "banner": {
    "content": "⚠️CinePro is still in development! [Learn more!](/in-dev)⚠️",
    "dismissible": true
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude"
    ]
  },
  "api": {
    "openapi": {
      "source": "/api-reference/openapi.json"
    },
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "examples": {
      "languages": ["javascript", "curl", "python", "php", "go", "java"]
    },
    "mdx": {
      "server": "http://localhost:3000"
    }
  },
  "seo": {
    "metatags": {
      "og:title": "CinePro Docs",
      "og:description": "CinePro is a powerful is an open-source movie and TV show scraper API designed to provide links to media content available on the internet. It is built with a focus on performance, reliability, and ease of use, making it an ideal choice for developers looking to integrate media content such as movies and tv shows into their applications.",
      "og:image": "/logo/light.svg"
    },
    "indexing": "navigable"
  }
}